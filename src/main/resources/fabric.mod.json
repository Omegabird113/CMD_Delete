  "authors": [
    "Omegabird113"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/cmd-delete",
    "sources": "https://github.com/Omegabird113/CMD_Delete",
    "issues": "https://github.com/Omegabird113/CMD_Delete/issues,"
  },
  "license": "Apache-2.0",
  "icon": "assets/cmd_delete/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "io.github.omegabird113.cmd_delete.CmdDeleteClient"
    ]
  },
  "mixins": [
    "cmd_delete.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.2",
    "fabric-api": ">=0.143.12+26.1",
    "minecraft": ">1.21.11 <=26.2"
  }
