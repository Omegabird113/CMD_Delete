{
  "schemaVersion": 1,
  "id": "cmd_delete",
  "version": "${version}",
  "name": "CMD + Delete",
  "description": "Fixes Minecraft’s text editing behavior on macOS so it has the proper modifier keybinds for cmd/option line/word navigation and deletion.",
  "authors": [
    "Omegabird113"
  ],
  "contact": {},
  "license": "Apache License 2.0",
  "icon": "assets/cmd_delete/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "io.github.omegabird113.cmd_delete.CmdDeleteClient"
    ]
  },
  "mixins": [
    "cmd_delete.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=0.143.12+26.1",
    "minecraft": ">=26.1-pre.1 <=26.2-pre.5"
  }
}
